# =============================================================================
# WARNING — every value in a Vite `VITE_*` env var is BAKED INTO THE PRODUCTION
# BUNDLE that ships to browsers. Do not paste real production keys here, do not
# rename this file to `.env`, and never commit `.env*` files. Use placeholders
# only. Production values belong in your hosting platform's secret store.
# =============================================================================

# Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Polar checkout is handled server-side by the API.
# Keep only API base URL in frontend env; do not expose Polar product IDs in browser.
VITE_API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# Optional: show calibration "last run inputs" technical panel (parcel AI → calibration). Default: hidden.
# VITE_DEV=true

# Auth Supabase (Cloud instance for authentication)
VITE_AUTH_SUPABASE_URL=https://your-auth-supabase-url.supabase.co
VITE_AUTH_SUPABASE_ANON_KEY=your-auth-supabase-anon-key

# Browser calls NestJS only (VITE_API_URL). Nest proxies satellite routes to the Python service.
# VITE_BACKEND_SERVICE_URL / VITE_SATELLITE_SERVICE_URL are not read by the web app — keep for Docker/ops docs only.
VITE_BACKEND_SERVICE_URL=http://localhost:8001
VITE_SATELLITE_SERVICE_URL=http://localhost:8001
# Optional: heatmap loading copy — set to gee or cdse to match backend SATELLITE_PROVIDER (auto → leave unset for generic text)
# VITE_SATELLITE_PROVIDER=cdse

# Google Analytics 4 (GA4)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity
VITE_CLARITY_ENABLED=true
VITE_ANALYTICS_DEBUG=false

# Map tiles: VITE_MAP_PROVIDER=default forces free OSM/Esri tiles even if VITE_MAPBOX_TOKEN is set
# (avoids Mapbox Raster/Static tile usage). Use mapbox + token only when you want Mapbox basemaps.
# VITE_MAP_PROVIDER=mapbox requires VITE_MAPBOX_TOKEN.
VITE_MAP_PROVIDER=default
VITE_MAPBOX_TOKEN=
