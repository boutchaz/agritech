# Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Polar checkout is handled server-side by the API.
# Keep only API base URL in frontend env; do not expose Polar product IDs in browser.
VITE_API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# Auth Supabase (Cloud instance for authentication)
VITE_AUTH_SUPABASE_URL=https://your-auth-supabase-url.supabase.co
VITE_AUTH_SUPABASE_ANON_KEY=your-auth-supabase-anon-key

# Backend Service (Satellite + PDF Generation + Data Processing)
VITE_BACKEND_SERVICE_URL=http://localhost:8001
# Legacy support (will be removed)
VITE_SATELLITE_SERVICE_URL=http://localhost:8001

# OpenWeather API (for weather forecasts)
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# Google Analytics 4 (GA4)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity
VITE_CLARITY_ENABLED=true
VITE_ANALYTICS_DEBUG=false

# Map Tile Provider ('default' or 'mapbox')
VITE_MAP_PROVIDER=default
VITE_MAPBOX_TOKEN=
