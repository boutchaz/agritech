{
  "name": "agriprofy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "export VITE_BUILD_TIME=$(date +%s) && tsc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "./scripts/db-migrate.sh",
    "db:sync": "./scripts/db-sync.sh",
    "db:reset": "supabase db reset",
    "db:reset:remote": "supabase db reset --linked",
    "db:seed": "psql $DATABASE_URL -f supabase/seed.sql",
    "db:seed:remote": "psql $DATABASE_URL -f supabase/seed.sql",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:push": "supabase db push --linked",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff --linked",
    "db:dump": "supabase db dump -f supabase/schema/public.sql --linked",
    "db:generate-types": "supabase gen types typescript --local > src/types/database.types.ts",
    "db:generate-types-remote": "supabase gen types typescript --linked > src/types/database.types.ts",
    "setup": "./scripts/setup-project.sh",
    "polar:setup": "npx tsx scripts/sync-polar-from-db.ts",
    "polar:sync": "npx tsx scripts/sync-polar-from-db.ts",
    "deploy:fresh:local": "./scripts/deploy-fresh.sh local",
    "deploy:fresh:remote": "./scripts/deploy-fresh.sh remote",
    "test:e2e": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "schema:pull": "./scripts/schema.sh pull",
    "schema:push": "./scripts/schema.sh push",
    "schema:diff": "./scripts/schema.sh diff",
    "schema:types": "./scripts/schema.sh types",
    "schema:reset": "./scripts/schema.sh reset",
    "schema:backup": "./scripts/schema.sh backup",
    "db:clean-remote": "./scripts/clean-remote-db.sh",
    "db:reset-cloud": "./scripts/reset-remote-cloud.sh",
    "prepare": "husky",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@casl/react": "^5.0.0",
    "@microsoft/clarity": "^1.0.2",
    "@polar-sh/sdk": "^0.35.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-query-devtools": "^5.87.4",
    "@tanstack/react-router": "^1.131.41",
    "@tanstack/router-devtools": "^1.131.42",
    "@tanstack/router-plugin": "^1.131.49",
    "@tauri-apps/api": "^1.5.3",
    "@testing-library/dom": "^10.4.1",
    "@types/leaflet": "^1.9.20",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "file-saver": "^2.0.5",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jotai": "^2.15.1",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "kbar": "^0.1.0-beta.48",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.552.0",
    "marked": "^17.0.1",
    "ol": "^10.6.1",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.63.0",
    "react-i18next": "^16.0.0",
    "react-is": "^19.2.0",
    "react-joyride": "^2.9.3",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.2.1",
    "socket.io-client": "^4.7.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^1.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^6.1.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.3",
    "playwright": "^1.56.1",
    "postcss": "^8",
    "tailwindcss": "^3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^4.0.16",
    "zod": "^4.1.12"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
