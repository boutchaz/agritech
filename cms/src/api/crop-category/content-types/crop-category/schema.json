{
  "kind": "collectionType",
  "collectionName": "crop_categories",
  "info": {
    "singularName": "crop-category",
    "pluralName": "crop-categories",
    "displayName": "Crop Category",
    "description": "Main categories of agricultural crops"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "name_fr": {
      "type": "string"
    },
    "name_ar": {
      "type": "string"
    },
    "value": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "description_fr": {
      "type": "text"
    },
    "description_ar": {
      "type": "text"
    },
    "icon": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_global": {
      "type": "boolean",
      "default": true
    },
    "organization_id": {
      "type": "string"
    },
    "crop_types": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::crop-type.crop-type",
      "mappedBy": "crop_category"
    }
  }
