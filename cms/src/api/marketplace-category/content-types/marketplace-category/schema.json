{
    "kind": "collectionType",
    "collectionName": "marketplace_categories",
    "info": {
        "singularName": "marketplace-category",
        "pluralName": "marketplace-categories",
        "displayName": "Marketplace Category",
        "description": "Categories for marketplace listings"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "description": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "products": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::marketplace-product.marketplace-product",
            "mappedBy": "categories"
        },
        "icon": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": false
                }
            }
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"],
            "pluginOptions": {
                "i18n": {
                    "localized": false
                }
            }
        },
        "sort_order": {
            "type": "integer",
            "default": 0,
            "pluginOptions": {
                "i18n": {
                    "localized": false
                }
            }
        },
        "is_featured": {
            "type": "boolean",
            "default": false,
            "pluginOptions": {
                "i18n": {
                    "localized": false
                }
            }
        }
    }
}