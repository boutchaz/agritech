{
  "kind": "collectionType",
  "collectionName": "crop_types",
  "info": {
    "singularName": "crop-type",
    "pluralName": "crop-types",
    "displayName": "Crop Type",
    "description": "Specific types of crops within categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "name_fr": {
      "type": "string"
    },
    "name_ar": {
      "type": "string"
    },
    "scientific_name": {
      "type": "string"
    },
    "value": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "description_fr": {
      "type": "text"
    },
    "description_ar": {
      "type": "text"
    },
    "icon": {
      "type": "string"
    },
    "growing_season": {
      "type": "json"
    },
    "climate_requirements": {
      "type": "json"
    },
    "soil_preferences": {
      "type": "json"
    },
    "water_requirements": {
      "type": "enumeration",
      "enum": ["low", "medium", "high"]
    },
    "growth_cycle_days": {
      "type": "integer"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_global": {
      "type": "boolean",
      "default": true
    },
    "organization_id": {
      "type": "string"
    },
    "crop_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::crop-category.crop-category",
      "inversedBy": "crop_types"
    },
    "varieties": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::variety.variety",
      "mappedBy": "crop_type"
    }
  }
}
