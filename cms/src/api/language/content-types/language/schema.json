{
  "kind": "collectionType",
  "collectionName": "languages",
  "info": {
    "singularName": "language",
    "pluralName": "languages",
    "displayName": "Language",
    "description": "Available languages for the application"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "native_name": {
      "type": "string"
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "locale": {
      "type": "string"
    },
    "direction": {
      "type": "enumeration",
      "enum": ["ltr", "rtl"],
      "default": "ltr"
    },
    "flag_icon": {
      "type": "string"
    },
    "is_default": {
      "type": "boolean",
      "default": false
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_global": {
      "type": "boolean",
      "default": true
    }
  }
}
