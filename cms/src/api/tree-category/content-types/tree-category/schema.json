{
  "kind": "collectionType",
  "collectionName": "tree_categories",
  "info": {
    "singularName": "tree-category",
    "pluralName": "tree-categories",
    "displayName": "Tree Category",
    "description": "Categories for organizing tree species"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "name_fr": {
      "type": "string"
    },
    "name_ar": {
      "type": "string"
    },
    "value": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "description_fr": {
      "type": "text"
    },
    "description_ar": {
      "type": "text"
    },
    "icon": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_global": {
      "type": "boolean",
      "default": true
    },
    "organization_id": {
      "type": "string"
    },
    "trees": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tree.tree",
      "mappedBy": "tree_category"
    }
  }
}
