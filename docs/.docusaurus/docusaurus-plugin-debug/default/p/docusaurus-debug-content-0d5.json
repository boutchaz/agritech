tion":"The Inventory & Stock Management system handles warehouse management, inventory tracking, and a multi-step reception batch workflow that covers receiving goods, quality control, decision routing, and financial processing. It is built with NestJS and Supabase across two primary modules: WarehousesModule and ReceptionBatchesModule.","source":"@site/docs/features/inventory.md","sourceDirName":"features","slug":"/features/inventory","permalink":"/features/inventory","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":13,"frontMatter":{"sidebar_position":13,"title":"Inventory & Stock Management"},"sidebar":"docs","previous":{"title":"Accounting & Finance","permalink":"/features/accounting"},"next":{"title":"Marketplace","permalink":"/features/marketplace"}},{"id":"features/marketplace","title":"Marketplace","description":"The AgroGina Marketplace is a B2B e-commerce platform that allows agricultural organizations to list, browse, and trade products. It combines two product sources -- dedicated marketplace listings and inventory items flagged for sale -- into a unified storefront. The system includes seller profiles, shopping carts, quote requests, orders with stock management, and a review system.","source":"@site/docs/features/marketplace.md","sourceDirName":"features","slug":"/features/marketplace","permalink":"/features/marketplace","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":9,"frontMatter":{"sidebar_position":9,"title":"Marketplace"},"sidebar":"docs","previous":{"title":"Inventory & Stock Management","permalink":"/features/inventory"},"next":{"title":"Compliance & Certifications","permalink":"/features/compliance"}},{"id":"features/notifications","title":"Notifications System","description":"Overview","source":"@site/docs/features/notifications.md","sourceDirName":"features","slug":"/features/notifications","permalink":"/features/notifications","draft":false,"unlisted":false,"tags":[],"version":"cu