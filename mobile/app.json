{
  "expo": {
    "name": "AgroGina",
    "slug": "agrogina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "agrogina",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8d011fff-336d-4f7a-a3d9-fd1b63149ea7"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrogina.field",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "AgroGina needs camera access to capture harvest photos and document crop conditions.",
        "NSLocationWhenInUseUsageDescription": "AgroGina needs location access to record harvest locations and track deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AgroGina needs background location for delivery tracking and geofenced clock-in.",
        "NSFaceIDUsageDescription": "AgroGina uses Face ID for secure and quick authentication.",
        "NSMicrophoneUsageDescription": "AgroGina needs microphone access for voice notes in the field."
      }
    },
    "android": {
      "package": "com.agrogina.field",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AgroGina to access your camera for harvest documentation."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AgroGina to use your location for field tracking and geofencing.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AgroGina to access your photos for documentation."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AgroGina to use Face ID for quick login."
        }
      ],
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8d011fff-336d-4f7a-a3d9-fd1b63149ea7"
      },
      "firebaseAnalyticsEnabled": true,
      "ga4MeasurementId": "G-XXXXXXXXXX",
      "ga4ApiSecret": "your-ga4-api-secret",
      "router": {}
    }
  }
}
