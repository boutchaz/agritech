# Server-agnostic Dokploy env – used by scripts/set-dokploy-env.mjs
# Copy to .env.dokploy and fill for each server (Codelovers, thebzlab, etc.). Do not commit.

# --- Dokploy API (required) ---
# Get API key from: Dokploy → Settings → Profile → API/CLI. Or use .cursor/mcp.json (dokploy-*-mcp).
DOKPLOY_URL=https://dokploy.yourdomain.com
DOKPLOY_API_KEY=your-dokploy-api-key

# --- Required per server (no hardcoded defaults) ---
SUPABASE_URL=https://your-supabase-host.example.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
POSTGRES_PASSWORD=
SUPABASE_NETWORK_NAME=your-supabase-compose_default
SUPABASE_DB_HOST=your-supabase-db-service-name
API_URL=https://your-api-host.example.com
DASHBOARD_URL=https://your-dashboard-host.example.com
SATELLITE_URL=https://your-satellite-host.example.com
CMS_URL=https://your-cms-host.example.com

# --- Optional: override compose IDs (defaults target Codelovers agritech project) ---
# COMPOSE_ID_DASHBOARD=
# COMPOSE_ID_API=
# COMPOSE_ID_SATELLITE=
# COMPOSE_ID_CMS=

# --- Optional: API / Traefik ---
# EXTERNAL_NETWORK_NAME=dokploy-network
# API_PUBLIC_HOST=api.example.com
# CORS_ORIGIN=

# --- Optional: satellite (GEE/CDSE) – or use .env.dokploy.satellite ---
# GEE_SERVICE_ACCOUNT=
# GEE_PRIVATE_KEY=
# GEE_PROJECT_ID=
# CDSE_CLIENT_ID=
# CDSE_CLIENT_SECRET=

# --- Optional: CMS / Strapi ---
# STRAPI_DB_PASSWORD=
# STRAPI_APP_KEYS=
# STRAPI_ADMIN_JWT_SECRET=

# --- Optional: SMTP / Polar ---
# SMTP_HOST= SMTP_PORT= SMTP_USER= SMTP_PASS= EMAIL_FROM=
# VITE_POLAR_*= STRAPI_API_TOKEN=
