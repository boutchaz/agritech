# Server-agnostic Dokploy env – used by scripts/set-dokploy-env.mjs
# Copy to .env.dokploy and fill for each server (Codelovers, thebzlab, etc.). Do not commit.
# thebzlab Supabase URL is typically https://supabase.thebzlab.online (not the Dokploy panel).
# Optional: keep a local-only `.env.dokploy.thebzlab` (gitignored) with SUPABASE_* for that stack.

# --- Dokploy API (required) ---
# Get API key from: Dokploy → Settings → Profile → API/CLI. Or use .cursor/mcp.json (dokploy-*-mcp).
DOKPLOY_URL=https://dokploy.yourdomain.com
DOKPLOY_API_KEY=your-dokploy-api-key

# --- Required per server (no hardcoded defaults) ---
SUPABASE_URL=https://your-supabase-host.example.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
POSTGRES_PASSWORD=
# Exact name from `docker network ls` (no _default suffix). e.g. agritech-supabase-8pqkna
# No local Supabase? Use dokploy-network.
SUPABASE_NETWORK_NAME=agritech-supabase-8pqkna
SUPABASE_DB_HOST=your-postgres-host
API_URL=https://your-api-host.example.com
DASHBOARD_URL=https://your-dashboard-host.example.com
SATELLITE_URL=https://your-satellite-host.example.com
CMS_URL=https://your-cms-host.example.com

# --- Optional: override compose IDs (defaults target Codelovers agritech project) ---
# COMPOSE_ID_DASHBOARD=
# COMPOSE_ID_API=
# COMPOSE_ID_SATELLITE=
# COMPOSE_ID_CMS=

# --- Optional: API / Traefik ---
# EXTERNAL_NETWORK_NAME=dokploy-network
# API_TRAEFIK_HOST=agritech-api-wf45ip-37-27-217-1.traefik.me
# API_PUBLIC_HOST=agriprofy-api.wearecodelovers.com
# CORS_ORIGIN= (optional; script auto-adds DASHBOARD_PUBLIC_HOST and API_PUBLIC_HOST when set)

# --- Optional: Dashboard / Traefik (compose labels need these for routing) ---
# DASHBOARD_TRAEFIK_HOST=agritech-dashboard-pu6ujw-aade68-37-27-217-1.traefik.me
# DASHBOARD_PUBLIC_HOST=agriprofy.wearecodelovers.com
# TRAEFIK_NETWORK=dokploy-network

# --- Optional: Satellite / Traefik ---
# SATELLITE_TRAEFIK_HOST=agritech-satellite-xxx-37-27-217-1.traefik.me
# SATELLITE_PUBLIC_HOST=satellite.wearecodelovers.com

# --- Optional: CMS / Traefik ---
# CMS_TRAEFIK_HOST=agritech-cms-xxx-37-27-217-1.traefik.me
# CMS_PUBLIC_HOST=cms.wearecodelovers.com

# --- Optional: satellite (GEE/CDSE) – or use .env.dokploy.satellite ---
# GEE_SERVICE_ACCOUNT=
# GEE_PRIVATE_KEY=
# GEE_PROJECT_ID=
# CDSE_CLIENT_ID=
# CDSE_CLIENT_SECRET=

# --- Optional: CMS / Strapi ---
# STRAPI_DB_PASSWORD=
# STRAPI_APP_KEYS=
# STRAPI_ADMIN_JWT_SECRET=

# --- Optional: SMTP / Polar ---
# SMTP_HOST= SMTP_PORT= SMTP_USER= SMTP_PASS= EMAIL_FROM=
# VITE_POLAR_*= STRAPI_API_TOKEN=
