# Migration runner DB URL (prefer private Docker network hostname, not public domain)
MIGRATIONS_DB_URL=postgresql://postgres:your_password@db:5432/postgres?sslmode=disable

# CORS
# Development
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://agritech-supabase-97b49f-196-75-242-33.traefik.me
# Production (uncomment and use these for deployment):
# CORS_ORIGIN=https://agritech-dashboard.thebzlab.online,https://agritech-marketplace.thebzlab.online,https://agritech.thebzlab.online

# Logging
LOG_LEVEL=debug

# CMS (Strapi)
CMS_URL=http://localhost:1337

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ===========================================
# SYSTEM HEALTH MONITORING & ALERTING
# ===========================================
# Email address to receive service-down alerts
ALERT_EMAIL_TO=your-email@example.com
# Optional: Slack / Discord / n8n webhook URL for alert notifications
ALERT_WEBHOOK_URL=
# Optional: Telegram bot alerts (get token from @BotFather, chat_id from @userinfobot)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
# Minutes to wait before re-sending the same alert (prevents spam)
ALERT_COOLDOWN_MINUTES=15
# How often (seconds) to probe all external services
HEALTH_CHECK_INTERVAL_SECONDS=60

# Email Configuration
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@example.com
FRONTEND_URL=https://agritech-dashboard.thebzlab.online
# After the 5-day satellite cron (parcelles en phase calibrage / Agromind). false = no email.
CALIBRATION_SATELLITE_CRON_EMAIL=true
# Optional explicit allowlist for OAuth/password-reset redirects.
# Falls back to CORS_ORIGIN + FRONTEND_URL when omitted.
AUTH_REDIRECT_ALLOWLIST=https://agritech-dashboard.thebzlab.online,https://agritech-marketplace.thebzlab.online,http://localhost:5173
# Optional dedicated secret for stateless cross-app exchange codes.
# Falls back to JWT_SECRET when omitted.
EXCHANGE_CODE_SECRET=change-me

# ===========================================
# POLAR.SH SUBSCRIPTION CONFIGURATION
# ===========================================
# Polar.sh API configuration for subscription management
# Get these from: https://polar.sh/settings
POLAR_ACCESS_TOKEN=polar_oat_your_access_token_here
POLAR_ORGANIZATION_ID=your-organization-uuid-here
POLAR_SERVER=sandbox  # sandbox or production
POLAR_WEBHOOK_SECRET=your_webhook_secret_for_signature_verification
# Checkout URL for direct link to payment page
POLAR_CHECKOUT_URL=https://sandbox-api.polar.sh/v1/checkout-links/your_checkout_link_id/redirect
# Product IDs for checkout (canonical formulas)
# Format: POLAR_<FORMULA>_<CYCLE>_PRODUCT_ID where cycle is MONTHLY|SEMIANNUAL|ANNUAL
POLAR_STARTER_MONTHLY_PRODUCT_ID=your_starter_monthly_product_id
POLAR_STARTER_SEMIANNUAL_PRODUCT_ID=your_starter_semiannual_product_id
POLAR_STARTER_ANNUAL_PRODUCT_ID=your_starter_annual_product_id
POLAR_STANDARD_MONTHLY_PRODUCT_ID=your_standard_monthly_product_id
POLAR_STANDARD_SEMIANNUAL_PRODUCT_ID=your_standard_semiannual_product_id
POLAR_STANDARD_ANNUAL_PRODUCT_ID=your_standard_annual_product_id
POLAR_PREMIUM_MONTHLY_PRODUCT_ID=your_premium_monthly_product_id
POLAR_PREMIUM_SEMIANNUAL_PRODUCT_ID=your_premium_semiannual_product_id
POLAR_PREMIUM_ANNUAL_PRODUCT_ID=your_premium_annual_product_id
POLAR_ENTERPRISE_MONTHLY_PRODUCT_ID=your_enterprise_monthly_product_id
POLAR_ENTERPRISE_SEMIANNUAL_PRODUCT_ID=your_enterprise_semiannual_product_id
POLAR_ENTERPRISE_ANNUAL_PRODUCT_ID=your_enterprise_annual_product_id

# Backward-compatible legacy product IDs (optional during migration)
POLAR_BASE_PRODUCT_ID=your_core_product_id
POLAR_ESSENTIAL_PRODUCT_ID=your_essential_product_id
POLAR_PROFESSIONAL_PRODUCT_ID=your_professional_product_id
POLAR_ENTERPRISE_PRODUCT_ID=your_enterprise_product_id
POLAR_ESSENTIAL_YEARLY_PRODUCT_ID=your_essential_yearly_product_id
POLAR_PROFESSIONAL_YEARLY_PRODUCT_ID=your_professional_yearly_product_id
POLAR_ENTERPRISE_YEARLY_PRODUCT_ID=your_enterprise_yearly_product_id

# Contract pricing defaults (MAD / ha / year HT)
SUBSCRIPTION_STARTER_PRICE_HT_PER_HA_YEAR=110
SUBSCRIPTION_STANDARD_PRICE_HT_PER_HA_YEAR=95
SUBSCRIPTION_PREMIUM_PRICE_HT_PER_HA_YEAR=80
SUBSCRIPTION_ENTERPRISE_PRICE_HT_PER_HA_YEAR=65
SUBSCRIPTION_VAT_RATE=0.20

# ===========================================
# SATELLITE SERVICE
# ===========================================
# URL of the FastAPI satellite/weather backend service
SATELLITE_SERVICE_URL=http://localhost:8001
# Shared secret for NestJS → FastAPI internal calls (no user token needed).
# Must match INTERNAL_SERVICE_TOKEN in the FastAPI satellite service env.
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32
