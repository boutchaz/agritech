{
  "test_types": [
    {
      "name": "Soil pH Test",
      "description": "Measures soil acidity/alkalinity level",
      "parameters": {
        "unit": "pH",
        "range": "0-14",
        "optimal": "6.0-7.0"
      }
    },
    {
      "name": "Soil Nitrogen Test",
      "description": "Measures nitrogen content in soil",
      "parameters": {
        "unit": "ppm",
        "range": "0-100",
        "optimal": "20-40"
      }
    },
    {
      "name": "Soil Phosphorus Test",
      "description": "Measures phosphorus content in soil",
      "parameters": {
        "unit": "ppm",
        "range": "0-100",
        "optimal": "25-50"
      }
    },
    {
      "name": "Soil Potassium Test",
      "description": "Measures potassium content in soil",
      "parameters": {
        "unit": "ppm",
        "range": "0-500",
        "optimal": "150-250"
      }
    },
    {
      "name": "Soil Organic Matter Test",
      "description": "Measures organic matter percentage in soil",
      "parameters": {
        "unit": "%",
        "range": "0-10",
        "optimal": "3-5"
      }
    },
    {
      "name": "Water Quality Test",
      "description": "Tests irrigation water quality and safety",
      "parameters": {
        "tests": ["pH", "EC", "TDS", "Heavy Metals"]
      }
    },
    {
      "name": "Plant Tissue Analysis",
      "description": "Analyzes nutrient levels in plant tissues",
      "parameters": {
        "nutrients": ["N", "P", "K", "Ca", "Mg", "Fe"]
      }
    }
  ],
