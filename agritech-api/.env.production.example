# Application
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1

# Traefik (for Dokploy deployment)
TRAEFIK_HOST=agritech-api.thebzlab.online

# Supabase (Self-hosted)
SUPABASE_URL=https://dokploy.thebzlab.online
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT (Use Supabase JWT Secret)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h

# Database (Supabase PostgreSQL - Self-hosted)
DATABASE_URL=postgresql://postgres:your_password@your_supabase_host:5433/postgres

# CORS (Add your frontend domains)
CORS_ORIGIN=https://agritech-dashboard.thebzlab.online,https://agritech-api.thebzlab.online

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
