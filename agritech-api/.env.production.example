# Application
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1

# Traefik (for Dokploy deployment)
TRAEFIK_HOST=agritech-api.thebzlab.online

# Supabase (Self-hosted)
SUPABASE_URL=https://dokploy.thebzlab.online
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT (Use Supabase JWT Secret)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h

# Database (Supabase PostgreSQL - Self-hosted)
DATABASE_URL=postgresql://postgres:your_password@your_supabase_host:5433/postgres
# Migration runner DB URL (private network only, do not expose Postgres publicly)
MIGRATIONS_DB_URL=postgresql://postgres:your_password@db:5432/postgres?sslmode=disable

# CORS (Frontend domains that can access this API)
CORS_ORIGIN=https://agritech-dashboard.thebzlab.online,https://agritech-marketplace.thebzlab.online,https://agritech.thebzlab.online

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Strapi CMS (for blog content)
STRAPI_API_URL=https://cms.thebzlab.online/api
STRAPI_API_TOKEN=your_strapi_api_token_here

# Frontend URL (for checkout redirect URLs)
FRONTEND_URL=https://agritech-dashboard.thebzlab.online
# Optional explicit allowlist for OAuth/password-reset redirects.
# Falls back to CORS_ORIGIN + FRONTEND_URL when omitted.
AUTH_REDIRECT_ALLOWLIST=https://agritech-dashboard.thebzlab.online,https://agritech-marketplace.thebzlab.online
# Optional dedicated secret for stateless cross-app exchange codes.
# Falls back to JWT_SECRET when omitted.
EXCHANGE_CODE_SECRET=replace-with-a-strong-random-secret

# ============================================================================
# POLAR.SH SUBSCRIPTION CONFIGURATION
# ============================================================================
# IMPORTANT: Create a PRODUCTION Polar organization at https://polar.sh
# Sandbox and production tokens/products are completely isolated.
#
# Steps to go production:
# 1. Create production org at polar.sh
# 2. Generate production access token (Settings > Tokens)
# 3. Create products: Essential ($25/mo), Professional ($75/mo), Enterprise (custom)
# 4. Create yearly products: Essential ($250/yr), Professional ($750/yr)
# 5. Register webhook endpoint: https://agritech-api.thebzlab.online/api/v1/webhooks/polar
# 6. Copy webhook secret from Polar dashboard
# 7. Update all values below with production IDs
#
# If behind Cloudflare: allowlist Polar webhook IPs:
#   3.134.238.10, 3.129.111.220, 52.15.118.168
#   74.220.50.0/24, 74.220.58.0/24
# ============================================================================

# Polar API (server-side only — NEVER expose in frontend VITE_ vars)
POLAR_ACCESS_TOKEN=polar_oat_PRODUCTION_TOKEN_HERE
POLAR_ORGANIZATION_ID=your-production-organization-uuid
POLAR_SERVER=production
POLAR_WEBHOOK_SECRET=your_production_webhook_secret

# Polar Checkout
POLAR_CHECKOUT_URL=https://api.polar.sh/v1/checkout-links/your_production_checkout_link_id/redirect

# Polar Product IDs (canonical formulas + cycles)
POLAR_STARTER_MONTHLY_PRODUCT_ID=your_production_starter_monthly_product_id
POLAR_STARTER_SEMIANNUAL_PRODUCT_ID=your_production_starter_semiannual_product_id
POLAR_STARTER_ANNUAL_PRODUCT_ID=your_production_starter_annual_product_id
POLAR_STANDARD_MONTHLY_PRODUCT_ID=your_production_standard_monthly_product_id
POLAR_STANDARD_SEMIANNUAL_PRODUCT_ID=your_production_standard_semiannual_product_id
POLAR_STANDARD_ANNUAL_PRODUCT_ID=your_production_standard_annual_product_id
POLAR_PREMIUM_MONTHLY_PRODUCT_ID=your_production_premium_monthly_product_id
POLAR_PREMIUM_SEMIANNUAL_PRODUCT_ID=your_production_premium_semiannual_product_id
POLAR_PREMIUM_ANNUAL_PRODUCT_ID=your_production_premium_annual_product_id
POLAR_ENTERPRISE_MONTHLY_PRODUCT_ID=your_production_enterprise_monthly_product_id
POLAR_ENTERPRISE_SEMIANNUAL_PRODUCT_ID=your_production_enterprise_semiannual_product_id
POLAR_ENTERPRISE_ANNUAL_PRODUCT_ID=your_production_enterprise_annual_product_id

# Backward-compatible legacy product IDs (optional during migration window)
POLAR_BASE_PRODUCT_ID=your_production_core_product_id
POLAR_ESSENTIAL_PRODUCT_ID=your_production_essential_product_id
POLAR_PROFESSIONAL_PRODUCT_ID=your_production_professional_product_id
POLAR_ENTERPRISE_PRODUCT_ID=your_production_enterprise_product_id
POLAR_ESSENTIAL_YEARLY_PRODUCT_ID=your_production_essential_yearly_product_id
POLAR_PROFESSIONAL_YEARLY_PRODUCT_ID=your_production_professional_yearly_product_id
POLAR_ENTERPRISE_YEARLY_PRODUCT_ID=your_production_enterprise_yearly_product_id

# Contract pricing defaults (MAD / ha / year HT)
SUBSCRIPTION_STARTER_PRICE_HT_PER_HA_YEAR=110
SUBSCRIPTION_STANDARD_PRICE_HT_PER_HA_YEAR=95
SUBSCRIPTION_PREMIUM_PRICE_HT_PER_HA_YEAR=80
SUBSCRIPTION_ENTERPRISE_PRICE_HT_PER_HA_YEAR=65
SUBSCRIPTION_VAT_RATE=0.20
