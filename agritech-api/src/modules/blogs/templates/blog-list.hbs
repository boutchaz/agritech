<div class="container section-lg">
  <!-- Page header -->
  <div style="margin-bottom:48px;text-align:center;max-width:760px;margin-left:auto;margin-right:auto;">
    <div class="eyebrow" style="margin-bottom:14px;">Journal · AgroGina</div>
    <h1 class="h-display" style="font-size:clamp(34px, 5vw, 56px);margin:0 0 14px;color:var(--ink-900);text-wrap:balance;">{{t.blogTitle}}</h1>
    <p style="font-size:17px;color:var(--ink-600);max-width:580px;margin:0 auto;line-height:1.55;text-wrap:pretty;">{{t.blogSubtitle}}</p>
  </div>

  {{#if featuredPosts.length}}
  <!-- Featured posts -->
  <section style="margin-bottom:64px;">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <span class="mono-cap" style="color:var(--ink-700);">À la une</span>
      <span style="flex:1;height:1px;background:var(--rule);"></span>
    </div>
    <div class="grid grid-cols-2" style="gap:16px;">
      {{#each featuredPosts}}
      {{> blog-card this}}
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if categories.length}}
  <!-- Category filter -->
  <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px;align-items:center;">
    <span class="mono-cap" style="color:var(--ink-500);margin-right:6px;">Filtrer</span>
    <a href="/blog?lang={{lang}}" class="badge {{#unless activeCategory}}badge-active{{/unless}}" style="text-decoration:none;">{{t.allCategories}}</a>
    {{#each categories}}
    <a href="/blog?category={{this.slug}}&lang={{../lang}}" class="badge {{#if (eq this.slug ../activeCategory)}}badge-active{{/if}}" style="text-decoration:none;">{{this.name}}</a>
    {{/each}}
  </div>
  {{/if}}

  <!-- All posts -->
  <section>
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <span class="mono-cap" style="color:var(--ink-700);">{{t.allArticles}}</span>
      <span style="flex:1;height:1px;background:var(--rule);"></span>
    </div>
    {{#if posts.length}}
    <div class="grid grid-cols-1 grid-cols-2 grid-cols-3" style="gap:16px;">
      {{#each posts}}
      {{> blog-card this}}
      {{/each}}
    </div>

    {{#if pagination}}
    <div style="display:flex;justify-content:center;align-items:center;gap:10px;margin-top:48px;padding-top:24px;border-top:1px solid var(--rule);">
      {{#if pagination.hasPrev}}
      <a href="/blog?page={{pagination.prevPage}}&lang={{lang}}{{#if activeCategory}}&category={{activeCategory}}{{/if}}" class="btn btn-ghost" style="font-size:13px;">← {{t.prevPage}}</a>
      {{/if}}
      <span class="mono" style="padding:0 14px;font-size:11px;color:var(--ink-500);">{{pagination.page}} / {{pagination.pageCount}}</span>
      {{#if pagination.hasNext}}
      <a href="/blog?page={{pagination.nextPage}}&lang={{lang}}{{#if activeCategory}}&category={{activeCategory}}{{/if}}" class="btn btn-ghost" style="font-size:13px;">{{t.nextPage}} →</a>
      {{/if}}
    </div>
    {{/if}}
    {{else}}
    <div style="text-align:center;padding:64px 0;color:var(--ink-500);border:1px dashed var(--rule);border-radius:14px;">
      <p style="font-size:15px;">{{t.noPosts}}</p>
    </div>
    {{/if}}
  </section>
</div>
