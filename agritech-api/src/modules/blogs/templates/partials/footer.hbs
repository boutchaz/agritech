<footer style="background:var(--ink-900);color:rgba(255,255,255,.7);padding:48px 0 24px;margin-top:80px;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr;gap:2rem;margin-bottom:2rem;">
      <div>
        <a href="{{appUrl}}/" style="display:inline-flex;align-items:center;gap:10px;color:white;text-decoration:none;margin-bottom:14px;">
          <picture>
            <source srcset="{{appUrl}}/assets/logo.webp" type="image/webp">
            <img src="{{appUrl}}/assets/logo.png" alt="AgroGina" style="height:32px;width:auto;display:block;">
          </picture>
          <span style="font-family:var(--font-display);font-size:24px;font-weight:500;letter-spacing:-0.02em;">agrogina</span>
        </a>
        <p style="font-size:13px;max-width:32rem;line-height:1.55;color:rgba(255,255,255,.6);">{{t.footerDescription}}</p>
      </div>
    </div>
    <div style="border-top:1px solid rgba(255,255,255,.1);padding-top:18px;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:14px;">
      <p class="mono" style="font-size:11px;color:rgba(255,255,255,.4);">© {{year}} Agrogina · {{t.allRightsReserved}}</p>
      <p style="font-size:11px;color:rgba(255,255,255,.55);">
        Conçu et développé par
        <a href="https://wearecodelovers.com/" target="_blank" rel="noopener noreferrer" style="color:#6ee7b7;font-weight:600;text-decoration:none;">CodeLovers</a>
      </p>
      <div class="mono" style="display:flex;gap:18px;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;">
        <a href="/blog" style="color:rgba(255,255,255,.55);">Blog</a>
        <a href="/rss.xml" style="color:rgba(255,255,255,.55);">RSS</a>
      </div>
    </div>
  </div>
</footer>
