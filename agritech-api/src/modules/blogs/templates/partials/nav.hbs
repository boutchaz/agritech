<header style="background:rgba(244,246,240,.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--rule);position:sticky;top:0;z-index:50;">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;gap:14px;">
    <!-- Logo -->
    <a href="{{appUrl}}/" style="display:flex;align-items:center;gap:10px;color:var(--ink-900);text-decoration:none;">
      <picture>
        <source srcset="{{appUrl}}/assets/logo.webp" type="image/webp">
        <img src="{{appUrl}}/assets/logo.png" alt="AgroGina" style="height:30px;width:auto;display:block;">
      </picture>
      <span style="font-family:var(--font-display);font-size:22px;font-weight:500;letter-spacing:-0.02em;">agrogina</span>
      <span style="display:none;width:1px;height:18px;background:var(--rule);margin-left:8px;" class="nav-divider"></span>
      <span class="mono-cap nav-eyebrow" style="display:none;">Journal · Saison 25/26</span>
    </a>

    <!-- Desktop nav -->
    <nav style="display:none;align-items:center;gap:22px;" class="desktop-nav">
      <a href="/blog" style="font-size:13px;font-weight:500;color:var(--ink-700);">Blog</a>

      {{#if categories}}
      <div style="position:relative;" class="dropdown">
        <button style="font-size:13px;font-weight:500;color:var(--ink-700);background:none;border:0;cursor:pointer;display:inline-flex;align-items:center;gap:6px;font-family:inherit;">
          Catégories
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="dropdown-menu" style="display:none;position:absolute;top:calc(100% + 6px);left:0;background:white;border:1px solid var(--rule);border-radius:12px;padding:6px;min-width:14rem;box-shadow:0 8px 24px rgba(20,40,30,.08);z-index:10;">
          {{#each categories}}
          <a href="/blog?category={{this.slug}}&lang={{../lang}}" style="display:block;padding:8px 12px;font-size:13px;color:var(--ink-800);border-radius:8px;">{{this.name}}</a>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <span style="width:1px;height:14px;background:var(--rule);"></span>

      <!-- Language switcher -->
      <div class="mono" style="display:flex;align-items:center;gap:8px;font-size:11px;">
        <a href="?lang=fr" style="color:{{#if (eq lang 'fr')}}var(--brand-700){{else}}var(--ink-500){{/if}};font-weight:{{#if (eq lang 'fr')}}600{{else}}400{{/if}};text-transform:uppercase;letter-spacing:0.06em;">FR</a>
        <span style="color:var(--ink-300);">·</span>
        <a href="?lang=ar" style="color:{{#if (eq lang 'ar')}}var(--brand-700){{else}}var(--ink-500){{/if}};font-weight:{{#if (eq lang 'ar')}}600{{else}}400{{/if}};text-transform:uppercase;letter-spacing:0.06em;">AR</a>
        <span style="color:var(--ink-300);">·</span>
        <a href="?lang=en" style="color:{{#if (eq lang 'en')}}var(--brand-700){{else}}var(--ink-500){{/if}};font-weight:{{#if (eq lang 'en')}}600{{else}}400{{/if}};text-transform:uppercase;letter-spacing:0.06em;">EN</a>
      </div>

      <!-- CTA -->
      <a href="{{appUrl}}/auth/register" class="btn btn-primary" style="padding:9px 14px;font-size:12px;">{{t.tryCta}}</a>
    </nav>

    <!-- Mobile hamburger -->
    <label for="mobile-menu-toggle" style="cursor:pointer;width:36px;height:36px;border:1px solid var(--rule);border-radius:8px;background:white;display:inline-flex;align-items:center;justify-content:center;color:var(--ink-700);" class="hamburger-label">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
    </label>
    <input type="checkbox" id="mobile-menu-toggle" style="display:none;" class="mobile-menu-checkbox">
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" style="display:none;background:var(--bg-canvas);border-top:1px solid var(--rule);padding:16px 20px;">
    <a href="/blog" style="display:block;padding:14px 12px;font-weight:500;color:var(--ink-900);font-size:16px;">Blog</a>
    {{#each categories}}
    <a href="/blog?category={{this.slug}}&lang={{../lang}}" style="display:block;padding:10px 12px 10px 28px;font-size:14px;color:var(--ink-600);">{{this.name}}</a>
    {{/each}}
    <div class="hairline" style="margin:12px 0;"></div>
    <div style="display:flex;gap:18px;padding:8px 12px;" class="mono">
      <a href="?lang=fr" style="font-size:11px;color:var(--ink-700);text-transform:uppercase;letter-spacing:0.08em;">Français</a>
      <a href="?lang=ar" style="font-size:11px;color:var(--ink-700);text-transform:uppercase;letter-spacing:0.08em;">العربية</a>
      <a href="?lang=en" style="font-size:11px;color:var(--ink-700);text-transform:uppercase;letter-spacing:0.08em;">English</a>
    </div>
    <a href="{{appUrl}}/auth/register" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:12px;">{{t.tryCta}}</a>
  </div>

  <style>
    @media (min-width: 768px) {
      .desktop-nav { display: flex !important; }
      .hamburger-label { display: none !important; }
    }
    @media (min-width: 1024px) {
      .nav-divider { display: inline-block !important; }
      .nav-eyebrow { display: inline !important; }
    }
    .dropdown:hover .dropdown-menu,
    .dropdown:focus-within .dropdown-menu { display: block !important; }
    .mobile-menu-checkbox:checked ~ .mobile-menu { display: block !important; }
    .mobile-menu-checkbox:checked + * + .mobile-menu { display: block !important; }
  </style>
</header>
