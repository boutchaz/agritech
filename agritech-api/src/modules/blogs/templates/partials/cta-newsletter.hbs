<div style="padding:1.25rem;background:#f0fdf4;border-radius:0.75rem;border:1px solid #dcfce7;">
  <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    <h3 style="font-size:0.9375rem;font-weight:600;color:#111827;">{{t.newsletterTitle}}</h3>
  </div>
  <p style="font-size:0.8125rem;color:#6b7280;margin-bottom:0.75rem;">{{t.newsletterDescription}}</p>
  <form id="newsletter-form-sidebar" class="newsletter-form" data-source="{{sourceSlug}}" data-msg-success="{{t.subscribeSuccess}}" data-msg-already="{{t.subscribeAlready}}" data-msg-error="{{t.subscribeError}}" data-btn-text="{{t.subscribe}}">
    <input type="email" name="email" required
      placeholder="{{t.emailPlaceholder}}"
      style="width:100%;padding:0.5rem 0.75rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.875rem;margin-bottom:0.5rem;outline:none;"
      onfocus="this.style.borderColor='#16a34a';this.style.boxShadow='0 0 0 2px rgba(22,163,74,0.1)'"
      onblur="this.style.borderColor='#d1d5db';this.style.boxShadow='none'">
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;font-size:0.8125rem;">
      {{t.subscribe}}
    </button>
    <div class="newsletter-message" style="display:none;margin-top:0.5rem;font-size:0.8125rem;padding:0.5rem;border-radius:0.375rem;"></div>
  </form>
</div>
