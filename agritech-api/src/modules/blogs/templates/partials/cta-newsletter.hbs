<div style="padding:22px;background:var(--bg-paper);border-radius:14px;border:1px solid var(--rule);">
  <div class="mono-cap" style="color:var(--brand-700);margin-bottom:10px;">Newsletter</div>
  <h3 class="h-display" style="font-size:18px;font-weight:500;color:var(--ink-900);margin-bottom:8px;line-height:1.2;">{{t.newsletterTitle}}</h3>
  <p style="font-size:13px;color:var(--ink-600);margin-bottom:14px;line-height:1.55;">{{t.newsletterDescription}}</p>
  <form id="newsletter-form-sidebar" data-source="{{sourceSlug}}" data-msg-success="{{t.subscribeSuccess}}" data-msg-already="{{t.subscribeAlready}}" data-msg-error="{{t.subscribeError}}" data-btn-text="{{t.subscribe}}">
    <input type="email" name="email" required
      placeholder="{{t.emailPlaceholder}}"
      style="width:100%;padding:11px 14px;border:1px solid var(--rule);border-radius:10px;font-size:13px;font-family:inherit;background:white;color:var(--ink-900);margin-bottom:8px;outline:none;transition:border-color .15s,box-shadow .15s;"
      onfocus="this.style.borderColor='var(--brand-500)';this.style.boxShadow='0 0 0 3px rgba(16,185,129,.12)'"
      onblur="this.style.borderColor='var(--rule)';this.style.boxShadow='none'">
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
      {{t.subscribe}}
    </button>
    <div class="newsletter-message" style="display:none;margin-top:10px;font-size:12px;padding:8px 10px;border-radius:8px;"></div>
  </form>
</div>
