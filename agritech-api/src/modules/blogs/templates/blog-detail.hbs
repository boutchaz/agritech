<div class="container section">
  <!-- Back link -->
  <a href="/blog?lang={{lang}}" style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:#6b7280;margin-bottom:1.5rem;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    {{t.backToBlog}}
  </a>

  <!-- Article header -->
  <header style="margin-bottom:2rem;">
    {{#if post.blog_category}}
    <a href="/blog?category={{post.blog_category.slug}}&lang={{lang}}" class="badge" style="margin-bottom:1rem;text-decoration:none;">{{post.blog_category.name}}</a>
    {{/if}}

    <h1 style="font-size:2rem;font-weight:700;color:#111827;line-height:1.3;margin-bottom:1rem;">{{post.title}}</h1>

    <div class="meta" style="margin-bottom:1rem;">
      <span class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {{post.author}}
      </span>
      {{#if post.publishedAtFormatted}}
      <span class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {{post.publishedAtFormatted}}
      </span>
      {{/if}}
      <span class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {{post.reading_time}} min
      </span>
    </div>

    {{> social-share shareUrl=canonicalUrl shareTitle=post.title}}
  </header>

  {{#if post.featured_image.url}}
  <div class="featured-image">
    <img src="{{post.featured_image.url}}" alt="{{#if post.featured_image.alternativeText}}{{post.featured_image.alternativeText}}{{else}}{{post.title}}{{/if}}">
  </div>
  {{/if}}

  <!-- Main content + sidebar -->
  <div class="layout-with-sidebar">
    <!-- Article content -->
    <article>
      <div class="prose">
        {{{post.contentHtml}}}
      </div>

      {{#if post.tags.length}}
      <div class="divider"></div>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        {{#each post.tags}}
        <a href="/blog?tag={{this}}&lang={{../lang}}" class="badge" style="text-decoration:none;">{{this}}</a>
        {{/each}}
      </div>
      {{/if}}

      <!-- Author card -->
      <div class="divider"></div>
      <div class="author-card">
        <div class="author-avatar">{{authorInitial}}</div>
        <div>
          <h3 style="font-weight:600;color:#111827;margin-bottom:0.25rem;">{{post.author}}</h3>
          <p style="font-size:0.875rem;color:#6b7280;">{{t.authorBio}}</p>
        </div>
      </div>

      <!-- Conversion banner -->
      <div class="cta-banner mt-12">
        <h2>{{t.ctaTitle}}</h2>
        <p>{{t.ctaDescription}}</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="{{appUrl}}/auth/register" class="btn btn-white">{{t.tryCta}}</a>
          <a href="{{appUrl}}/demo" class="btn btn-ghost">{{t.bookDemo}}</a>
        </div>
      </div>

      {{#if relatedPosts.length}}
      <!-- Related articles -->
      <div class="mt-12">
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1.25rem;">{{t.relatedArticles}}</h2>
        <div class="grid grid-cols-2" style="gap:1.5rem;">
          {{#each relatedPosts}}
          {{> blog-card this}}
          {{/each}}
        </div>
      </div>
      {{/if}}
    </article>

    <!-- Sidebar -->
    <aside class="sidebar-sticky">
      {{#if headings.length}}
      <div class="toc mb-6">
        <h3>{{t.tableOfContents}}</h3>
        <ul>
          {{#each headings}}
          <li><a href="#{{this.id}}" class="{{#if (eq this.level 'h3')}}toc-h3{{/if}}">{{this.text}}</a></li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{> cta-newsletter sourceSlug=post.slug}}

      <div style="margin-top:1.5rem;">
        {{> cta-demo}}
      </div>
    </aside>
  </div>
</div>
